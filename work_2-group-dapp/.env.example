# Sepolia RPC endpoint, for example from Alchemy, Infura, or QuickNode.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Deployer wallet private key. Never commit a real private key.
SEPOLIA_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional: used by `npm run export:abi` after deployment.
CONTRACT_ADDRESS=0xDEPLOYED_CONTRACT_ADDRESS
CONTRACT_NETWORK=sepolia
